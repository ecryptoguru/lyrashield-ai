# NOTE: `pnpm build` (Next.js page-data collection) reads env from process.env — a
# root .env alone is not loaded for the build. For a local production build either
# export DATABASE_URL/BETTER_AUTH_SECRET/BETTER_AUTH_URL/NEXT_PUBLIC_APP_URL, or place
# an .env in apps/web/. `pnpm dev` and the test suite load this root .env fine.

# Database
DATABASE_URL="postgresql://lyrashield:lyrashield@localhost:5432/lyrashield?schema=public"
# Direct URL for migrations (bypasses PgBouncer pooler). Defaults to DATABASE_URL if not set.
DATABASE_DIRECT_URL="postgresql://lyrashield:lyrashield@localhost:5432/lyrashield?schema=public"
# Production only: privileged connection for the small, explicitly reviewed
# cross-workspace boundary. Never use this client for ordinary request queries.
DATABASE_SYSTEM_URL=""

# Redis (redis:// — reserved for the BullMQ job queue, Sprint 4+)
REDIS_URL="redis://:lyrashield-dev-redis@localhost:6379"

# Upstash Redis REST — distributed rate limiting in production.
# HTTPS REST endpoint + token (NOT the redis:// URL above). Leave blank in dev
# to use the in-memory limiter. If the URL is set, the token is required.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Better Auth
BETTER_AUTH_SECRET="replace-with-a-strong-secret-key-min-32-chars"
BETTER_AUTH_URL="http://localhost:3001"
# Comma-separated extra application origins trusted for auth/CSRF (staging or
# an intentional preview). Do not add the marketing site merely because it
# shares the parent domain; Lite Check has its own route-scoped CORS policy.
# BETTER_AUTH_URL is always trusted.
ADDITIONAL_TRUSTED_ORIGINS=""
# Leave unset for a host-only application session. Set only when a reviewed
# product flow genuinely requires credential sharing across subdomains.
# BETTER_AUTH_COOKIE_DOMAIN=".example.com"

# Social OAuth. Register each callback exactly as
# https://<app-origin>/api/auth/callback/<provider> (GitHub/Google) or
# https://<app-origin>/api/auth/callback/microsoft (Microsoft Entra ID).
# OAuth sign-up is open when the provider is configured; existing accounts can also link it.
# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID OAuth (https://entra.microsoft.com/)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
# Use `common` for work/school and personal Microsoft accounts, or the exact
# tenant ID only when beta access is intentionally tenant-restricted.
AZURE_AD_TENANT_ID="common"

# GitHub App (for repo scanning — Sprint 3)
GITHUB_APP_ID=""
# App slug from the GitHub App settings URL (github.com/apps/<slug>) —
# used to build the public install URL. NOT the numeric app id.
GITHUB_APP_SLUG=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_MARKETING_URL="http://localhost:4321"
PORT=3001
# Set only behind a proxy with a documented authoritative-header contract. Azure
# Container Apps appends its hop to X-Forwarded-For; the app selects the rightmost
# value. Other ingress products may require stripping incoming copies instead.
TRUSTED_PROXY_IP_HEADER=""

# Scan Engine (Sprint 5+)
LYRASHIELD_LLM="openai/gpt-4o"
LYRASHIELD_RUNTIME_BACKEND="docker"
# Required by repository-scan workers. Use a dedicated internal Docker network.
LYRASHIELD_ENGINE_SANDBOX_NETWORK="lyrashield-sandbox"
SCANNER_PHASE_TIMEOUT_MS="600000"
# Safe/Quick/Standard use Luna/medium. Deep/Custom use Terra/medium for the
# coordinator and Luna/medium for focused child specialists.
# Empty routed values fall back to LYRASHIELD_LLM.
LYRASHIELD_LUNA_LLM=""
LYRASHIELD_TERRA_LLM=""
LYRASHIELD_WORKER_CONCURRENCY="1"
PLATFORM_MAX_SCAN_BUDGET_USD="50"
LLM_API_KEY=""
LLM_API_BASE=""
LLM_API_VERSION=""
# Production: pin an inspected digest, never a mutable tag.
# LYRASHIELD_IMAGE="ghcr.io/usestrix/strix-sandbox@sha256:478e0b37ec83b2ba8c6e159593cb46d5dc9b624a45d6a9bb606851b83058d284"
LYRASHIELD_TELEMETRY="0"
LYRASHIELD_ENGINE_PATH=""

# Azure OpenAI (optional — use these OR the generic LLM_API_KEY/LLM_API_BASE)
# LYRASHIELD_LLM="azure/gpt-5.6-terra" # fallback
# LYRASHIELD_LUNA_LLM="azure/gpt-5.6-luna"
# LYRASHIELD_TERRA_LLM="azure/gpt-5.6-terra"
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
# AZURE_OPENAI_API_BASE=""
AZURE_API_VERSION="v1"
# AZURE_OPENAI_API_VERSION=""

# Azure AI project / serverless (optional — e.g. azure_ai/gpt-5.6-terra)
# LYRASHIELD_LLM="azure_ai/gpt-5.6-terra" # fallback
# LYRASHIELD_LUNA_LLM="azure_ai/gpt-5.6-luna"
# LYRASHIELD_TERRA_LLM="azure_ai/gpt-5.6-terra"
AZURE_AI_API_KEY=""
AZURE_AI_API_BASE=""

# Evidence Storage (Cloudflare R2 — 10GB free, zero egress)
S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="lyrashield-evidence"
S3_REGION="auto"

# Docker Compose stores localhost evidence in an encrypted local volume automatically.
# For a direct host-worker run only, opt in explicitly (never enable this in production).
LYRASHIELD_LOCAL_EVIDENCE_STORAGE=""
LYRASHIELD_LOCAL_EVIDENCE_DIR=""

# Email (Brevo — optional until email verification/password reset is enabled)
# When disabled, Brevo is not required for sign-up.
LYRASHIELD_REQUIRE_EMAIL_VERIFICATION="0"
BREVO_API_KEY=""
# Use a verified Brevo sender address only (display names are configured by Brevo).
EMAIL_FROM="noreply@localhost"
NOTIFICATION_FROM_EMAIL=""

# Notifications (Sprint 9)
SLACK_WEBHOOK_URL=""
DISCORD_WEBHOOK_URL=""

# Billing (Sprint 10)
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Monitoring
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
