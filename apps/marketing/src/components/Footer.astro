---
const xUrl = __MARKETING_X_URL__
---

<footer class="border-t border-border bg-bg py-8 text-text-muted">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-4 sm:flex-row sm:px-6 lg:px-8">
    <p class="max-w-md text-center text-sm sm:text-left">LyraShield AI · Release assurance for AI-built software. In active development.</p>
    <nav aria-label="Footer" class="flex flex-wrap items-center justify-center gap-x-6 gap-y-1">
      <a href="/methodology" class="inline-flex min-h-11 items-center text-sm hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
        Methodology
      </a>
      <a href="/blog" class="inline-flex min-h-11 items-center text-sm hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
        Resources
      </a>
      <a href="/tools" class="inline-flex min-h-11 items-center text-sm hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
        Tools
      </a>
      <a href="/scan" class="inline-flex min-h-11 items-center text-sm hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">Free scan</a>
      <a href="/terms" class="inline-flex min-h-11 items-center text-sm hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">Terms</a>
      <a href="/rss.xml" class="inline-flex min-h-11 items-center text-sm hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
        RSS
      </a>
      {xUrl && (
        <a href={xUrl} rel="me noreferrer" target="_blank" class="inline-flex min-h-11 items-center text-sm hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
          X
        </a>
      )}
    </nav>
  </div>
</footer>
