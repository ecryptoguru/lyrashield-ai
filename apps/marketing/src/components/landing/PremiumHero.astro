---
import premiumHeroAvif from "../../assets/premium-hero.avif"
import premiumHeroJpeg from "../../assets/premium-hero.jpg"
import premiumHeroWebp from "../../assets/premium-hero.webp"
---

<section class="premium-hero" aria-labelledby="premium-hero-title">
  <picture class="premium-hero__poster">
    <source srcset={premiumHeroAvif.src} type="image/avif" />
    <source srcset={premiumHeroWebp.src} type="image/webp" />
    <img
      src={premiumHeroJpeg.src}
      width={premiumHeroJpeg.width}
      height={premiumHeroJpeg.height}
      alt=""
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </picture>
  <div class="premium-hero__veil" aria-hidden="true"></div>
  <div class="premium-hero__content">
    <p class="premium-hero__eyebrow">Release assurance for AI-built apps</p>
    <h1 id="premium-hero-title">Know what was tested before you ship.</h1>
    <p class="premium-hero__lede">
      Turn an authorized target, retained evidence, and a fresh retest into one reviewable assurance record.
    </p>
    <div class="premium-hero__actions">
      <a class="premium-hero__primary" href="/scan" data-cta-id="premium-hero-lite-check">Run a free Lite Check</a>
      <a class="premium-hero__secondary" href="#assurance-world" data-cta-id="premium-hero-assurance-world">
        See the assurance loop <span aria-hidden="true">↓</span>
      </a>
    </div>
    <p class="premium-hero__boundary">Passive public-surface check · No account required · Full platform in active development</p>
  </div>
  <div class="premium-hero__rail" aria-hidden="true"><span>01</span><i></i><span>07</span></div>
</section>

<style>
  .premium-hero {
    --hero-cyan: #54d6df;
    position: relative;
    display: grid;
    min-height: min(920px, calc(100svh - 4rem));
    overflow: hidden;
    isolation: isolate;
    color: #edf6fb;
    background: #08111c;
  }

  .premium-hero__poster,
  .premium-hero__poster img,
  .premium-hero__veil {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .premium-hero__poster {
    z-index: -2;
  }

  .premium-hero__poster img {
    display: block;
    object-fit: cover;
    object-position: 68% 50%;
    filter: saturate(0.88) contrast(1.08);
  }

  .premium-hero__veil {
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(8, 17, 28, 0.98) 0%, rgba(8, 17, 28, 0.89) 42%, rgba(8, 17, 28, 0.18) 78%),
      linear-gradient(180deg, rgba(8, 17, 28, 0.16), rgba(8, 17, 28, 0.88));
  }

  .premium-hero__content {
    align-self: center;
    width: min(100% - 2rem, 1280px);
    margin-inline: auto;
    padding-block: clamp(7rem, 15vh, 11rem) 6rem;
  }

  .premium-hero__eyebrow,
  .premium-hero__boundary {
    font-family: "JetBrains Mono Variable", monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .premium-hero__eyebrow {
    margin: 0 0 1.4rem;
    color: var(--hero-cyan);
    font-size: clamp(0.78rem, 1vw, 0.95rem);
    font-weight: 650;
  }

  h1 {
    max-width: 820px;
    margin: 0;
    font-family: "Bricolage Grotesque Variable", sans-serif;
    font-size: clamp(3.8rem, 7.4vw, 7.4rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  .premium-hero__lede {
    max-width: 640px;
    margin: 2rem 0 0;
    color: #b7cad8;
    font-size: clamp(1.05rem, 1.45vw, 1.28rem);
    line-height: 1.65;
  }

  .premium-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 2.25rem;
  }

  .premium-hero__actions a {
    display: inline-flex;
    min-height: 3.25rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(84, 214, 223, 0.42);
    border-radius: 0.25rem;
    padding: 0.85rem 1.25rem;
    font-weight: 750;
    text-decoration: none;
    transition: transform 160ms ease, background-color 160ms ease, border-color 160ms ease;
  }

  .premium-hero__actions a:hover {
    transform: translateY(-2px);
  }

  .premium-hero__actions a:focus-visible {
    outline: 3px solid #f5b84b;
    outline-offset: 4px;
  }

  .premium-hero__primary {
    color: #08111c;
    background: var(--hero-cyan);
    box-shadow: 0 0 38px rgba(84, 214, 223, 0.18);
  }

  .premium-hero__secondary {
    gap: 1.5rem;
    color: #edf6fb;
    background: rgba(8, 17, 28, 0.62);
  }

  .premium-hero__boundary {
    margin: 1.5rem 0 0;
    color: #91a7b8;
    font-size: 0.69rem;
    line-height: 1.6;
  }

  .premium-hero__rail {
    position: absolute;
    right: clamp(1rem, 3vw, 3rem);
    bottom: 2.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #91a7b8;
    font: 600 0.66rem/1 "JetBrains Mono Variable", monospace;
  }

  .premium-hero__rail i {
    display: block;
    width: min(10vw, 7rem);
    height: 1px;
    background: linear-gradient(90deg, var(--hero-cyan), rgba(84, 214, 223, 0.15));
  }

  @media (max-width: 720px) {
    .premium-hero {
      min-height: calc(100svh - 3.5rem);
    }

    .premium-hero__poster img {
      object-position: 58% 50%;
    }

    .premium-hero__veil {
      background: linear-gradient(180deg, rgba(8, 17, 28, 0.72) 0%, rgba(8, 17, 28, 0.98) 68%);
    }

    .premium-hero__content {
      align-self: end;
      padding-block: 9rem 5.5rem;
    }

    h1 {
      font-size: clamp(3.25rem, 15vw, 5.2rem);
    }

    .premium-hero__actions {
      display: grid;
    }

    .premium-hero__rail {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .premium-hero__actions a {
      transition: none;
    }
  }
</style>
