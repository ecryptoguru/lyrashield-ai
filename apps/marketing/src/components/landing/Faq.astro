---
interface Item {
  q: string
  a: string
}

interface Props {
  items: Item[]
}

const { items } = Astro.props
---

<section aria-labelledby="faq-heading" class="px-4 py-24 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl">
    <h2 id="faq-heading" class="text-center text-3xl font-semibold tracking-tight text-text sm:text-4xl">
      Questions
    </h2>
    <div class="mt-12 space-y-4">
      {items.map((item, index) => (
        <details class="group rounded-lg border border-border bg-bg-raised" data-question-id={`question_${index + 1}`}>
          <summary class="cursor-pointer list-none rounded-lg p-4 font-medium text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
            <span class="flex items-center justify-between gap-4">
              {item.q}
              <svg viewBox="0 0 20 20" class="size-5 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true"><path d="m5 7.5 5 5 5-5" /></svg>
            </span>
          </summary>
          <div class="border-t border-border px-4 pt-3 pb-4 text-text-muted">
            <p class="leading-7">{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
