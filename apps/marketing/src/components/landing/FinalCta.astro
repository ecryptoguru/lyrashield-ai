---
import WaitlistForm from "@components/WaitlistForm.astro"
---

<section id="waitlist" aria-labelledby="waitlist-heading" class="px-4 py-24 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl text-center" data-reveal-group>
    <h2 id="waitlist-heading" data-reveal class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">
      Get release assurance updates.
    </h2>
    <p data-reveal class="mt-5 text-lg leading-8 text-text-muted">
      Stay in the loop on new evidence states, scan depth, and ways to share an honest assurance record.
    </p>
  </div>
  <div class="mt-12" data-reveal>
    <WaitlistForm />
  </div>
</section>
