---
import WaitlistForm from "@components/WaitlistForm.astro"
---

<section id="waitlist" aria-labelledby="waitlist-heading" class="px-4 py-24 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <h2 id="waitlist-heading" class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">
      Get early access.
    </h2>
    <p class="mt-4 text-lg text-text-muted">
      Join the waitlist for the private beta and build previews.
    </p>
  </div>
  <div class="mt-12">
    <WaitlistForm />
  </div>
</section>
