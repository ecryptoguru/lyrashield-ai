---
import { getCollection, getEntry, render } from "astro:content"
import BlogPost from "@layouts/BlogPost.astro"
import { markdownWordCount, readingMinutes as calculateReadingMinutes } from "../../lib/blog-content"

export async function getStaticPaths() {
  const posts = await getCollection("blog")
  const includeDrafts = import.meta.env.DEV

  return posts
    .filter((post) => includeDrafts || !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }))
}

const { post } = Astro.props
const { Content, headings = [] } = await render(post)
const [heroImage, author] = await Promise.all([
  getEntry(post.data.heroImage),
  getEntry(post.data.author),
])

if (!heroImage) {
  throw new Error(`Missing catalog image for blog post: ${post.id}`)
}
if (!author) {
  throw new Error(`Missing author for blog post: ${post.id}`)
}

const wordCount = markdownWordCount(post.body ?? "")
const readingMinutes = calculateReadingMinutes(post.body ?? "")

// Related posts: tag-overlap scoring, ties broken by recency, top 3.
const allPosts = await getCollection("blog", (entry) => !entry.data.draft)
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => ({
    entry: p,
    overlap: p.data.tags.filter((tag) => post.data.tags.includes(tag)).length,
  }))
  .filter((p) => p.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap || b.entry.data.pubDate.getTime() - a.entry.data.pubDate.getTime())
  .slice(0, 3)
  .map((p) => p.entry)
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={author}
  tags={post.data.tags}
  draft={post.data.draft}
  canonical={post.data.canonical}
  faq={post.data.faq}
  headings={headings}
  readingMinutes={readingMinutes}
  relatedPosts={relatedPosts}
  wordCount={wordCount}
  heroImage={heroImage}
>
  <Content />
</BlogPost>
