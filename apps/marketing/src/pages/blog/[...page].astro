---
import Base from "@layouts/Base.astro"
import { getCollection } from "astro:content"
import type { GetStaticPathsOptions } from "astro"

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  // ponytail: localhost previews include drafts; production keeps the existing publish gate.
  const posts = await getCollection("blog", (entry) => import.meta.env.DEV || !entry.data.draft)
  const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  return paginate(sortedPosts, { pageSize: 10 })
}

const { page } = Astro.props

const origin = Astro.site?.origin || "http://localhost:4321"
const canonical = new URL(page.currentPage === 1 ? "/blog" : page.url.current, origin).toString()
const title =
  page.currentPage === 1
    ? "AI App Security Resources | LyraShield AI"
    : `AI App Security Resources — Page ${page.currentPage} | LyraShield AI`
const description = "Read LyraShield AI research and practical guidance on securing AI-built apps, interpreting security evidence, verifying findings, and retesting fixes."
const jsonLd = [
  { "@context": "https://schema.org", "@type": "CollectionPage", name: "AI app security resources", description, url: canonical, isPartOf: { "@id": `${origin}/#website` } },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [{ "@type": "ListItem", position: 1, name: "Home", item: `${origin}/` }, { "@type": "ListItem", position: 2, name: "Resources", item: new URL("/blog", origin).toString() }] },
]
---

<Base title={title} description={description} canonical={canonical} jsonLd={jsonLd}>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8">
    <nav aria-label="Breadcrumb" class="mb-8 text-sm text-text-muted"><a href="/" class="hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">Home</a><span class="mx-2" aria-hidden="true">/</span><span aria-current="page">Resources</span></nav>
    <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">AI app security resources</h1>
    <p class="mt-4 text-lg text-text-muted">{description}</p>

    {import.meta.env.DEV && (
      <p class="mt-3 text-sm text-text-muted">Local preview includes unpublished drafts.</p>
    )}

    {page.data.length === 0 && (
      <section aria-labelledby="start-heading" class="mt-12 border-y border-border py-10">
        <h2 id="start-heading" class="text-2xl font-semibold text-text">Start with the published resources</h2>
        <p class="mt-4 max-w-2xl leading-7 text-text-muted">The first long-form articles are still in editorial review. In the meantime, inspect the evidence model or run a focused browser-local check.</p>
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          <a href="/methodology" class="rounded-xl border border-border bg-bg-raised p-5 hover:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"><span class="font-semibold text-text">Evidence methodology</span><span class="mt-2 block text-sm leading-6 text-text-muted">How scope, coverage, verification, retest state, and limitations are recorded.</span></a>
          <a href="/tools" class="rounded-xl border border-border bg-bg-raised p-5 hover:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"><span class="font-semibold text-text">Free security tools</span><span class="mt-2 block text-sm leading-6 text-text-muted">Five private checks for launch controls, headers, secrets, RLS, and sessions.</span></a>
        </div>
      </section>
    )}

    <ul class="mt-12 space-y-8">
      {page.data.map((post) => (
        <li class="rounded-lg border border-border bg-bg-raised p-6">
          <a href={`/blog/${post.id}`} class="text-xl font-semibold tracking-tight text-text hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
            {post.data.title}
          </a>
          <p class="mt-2 text-text-muted">{post.data.description}</p>
          <p class="mt-4 text-sm text-text-muted">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
            </time>
            {post.data.tags.length > 0 && (
              <span class="ml-2">· {post.data.tags.join(", ")}</span>
            )}
          </p>
        </li>
      ))}
    </ul>

    {(page.url.prev || page.url.next) && (
      <nav aria-label="Blog pagination" class="mt-12 flex items-center justify-between border-t border-border pt-6">
        {page.url.prev ? (
          <a href={page.url.prev} class="text-sm font-medium text-accent hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">← Newer posts</a>
        ) : <span aria-hidden="true" />}
        <span class="text-sm text-text-muted">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next ? (
          <a href={page.url.next} class="text-sm font-medium text-accent hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">Older posts →</a>
        ) : <span aria-hidden="true" />}
      </nav>
    )}
  </section>
</Base>
