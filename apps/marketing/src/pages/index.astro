---
import Base from "@layouts/Base.astro"
import Hero from "@components/landing/Hero.astro"
import HomeLiteScan from "@components/landing/HomeLiteScan.astro"
import Problem from "@components/landing/Problem.astro"
import AssuranceRecord from "@components/landing/AssuranceRecord.astro"
import Loop from "@components/landing/Loop.astro"
import WhereYouWork from "@components/landing/WhereYouWork.astro"
import TwoDepths from "@components/landing/TwoDepths.astro"
import FreeToolsPreview from "@components/landing/FreeToolsPreview.astro"
import Faq from "@components/landing/Faq.astro"
import FinalCta from "@components/landing/FinalCta.astro"

const siteUrl = Astro.site?.toString() || "http://localhost:4321"
const siteOrigin = Astro.site?.origin || "http://localhost:4321"
const pageUrl = new URL("/", siteOrigin).toString()
const xUrl = __MARKETING_X_URL__ || undefined

const description =
  "LyraShield AI records what was tested, separates detected risks from retest-confirmed fixes, and creates an assurance report for AI-built apps."

const faqItems = [
  {
    q: "What is release assurance for an AI-built app?",
    a: "It is a review record that states which authorized checks ran, what they covered, the evidence behind each result, and what a retest established before a release ships.",
  },
  {
    q: "Is this live today?",
    a: "The passive Lite Check and five browser-local tools are live. The full release-assurance platform is in active development; the waitlist gets first invites and early design-partner access.",
  },
  {
    q: "What does a LyraShield result actually prove?",
    a: "Only what the retained evidence supports. New scans distinguish detected candidates, independently verified findings, validated fixes, inconclusive retests, and checks that were limited or not applicable.",
  },
  {
    q: "Does LyraShield open Fix PRs today?",
    a: "Not yet. LyraShield creates approval-gated fix proposals, but PR execution stays blocked until the patch is generated server-side and bound to the exact approval.",
  },
  {
    q: "Does it replace my existing tools?",
    a: "No. SCA, secret scanning, URL checks, and repository review are coverage layers inside a wider assurance workflow. Specialist tools may still provide deeper coverage in their category.",
  },
  {
    q: "What does it cost?",
    a: "Pricing lands with early access.",
  },
]

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteOrigin}/#organization`,
    name: "LyraShield AI",
    url: siteUrl,
    logo: new URL("/favicon.svg", siteOrigin).toString(),
    description,
    knowsAbout: [
      "AI application security",
      "release assurance",
      "security evidence",
      "independent finding verification",
      "security retesting",
    ],
    ...(xUrl ? { sameAs: [xUrl] } : {}),
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteOrigin}/#website`,
    name: "LyraShield AI",
    url: siteUrl,
    inLanguage: "en-US",
    publisher: { "@id": `${siteOrigin}/#organization` },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": `${pageUrl}#webpage`,
    name: "Release assurance for AI-built apps",
    description,
    url: pageUrl,
    inLanguage: "en-US",
    dateModified: "2026-07-17",
    isPartOf: { "@id": `${siteOrigin}/#website` },
    about: { "@id": `${pageUrl}#application` },
    mainEntity: { "@id": `${pageUrl}#faq` },
  },
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "@id": `${pageUrl}#application`,
    name: "LyraShield AI",
    applicationCategory: "SecurityApplication",
    operatingSystem: "Web",
    description,
    url: pageUrl,
    provider: { "@id": `${siteOrigin}/#organization` },
    isPartOf: { "@id": `${siteOrigin}/#website` },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": `${pageUrl}#faq`,
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.a,
      },
    })),
  },
]
---

<Base
  title="LyraShield AI — Release assurance for AI-built apps"
  description={description}
  canonical={pageUrl}
  jsonLd={jsonLd}
>
  <Hero />
  <HomeLiteScan />
  <Problem />
  <AssuranceRecord />
  <Loop />
  <TwoDepths />
  <FreeToolsPreview />
  <WhereYouWork />
  <Faq items={faqItems} />
  <FinalCta />
</Base>
