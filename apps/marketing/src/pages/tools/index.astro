---
import Base from "@layouts/Base.astro"
import { tools, toolUrl } from "../../lib/tools"
const origin = Astro.site?.origin || "http://localhost:4321"
const canonical = new URL("/tools", origin).toString()
const jsonLd = [{ "@context": "https://schema.org", "@type": "CollectionPage", name: "Free Security Tools for AI-Built Apps", url: canonical, hasPart: tools.map((tool) => ({ "@type": "WebApplication", name: tool.title, url: new URL(toolUrl(tool.slug), origin).toString() })) }]
---
<Base title="Free Security Tools for AI-Built Apps | LyraShield AI" description="Use privacy-first free security tools to review launch readiness, headers, secrets, RLS policies, and JWT sessions." canonical={canonical} jsonLd={jsonLd}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:py-20"><h1 class="max-w-3xl text-4xl font-semibold tracking-tight text-text sm:text-5xl">Free security tools for AI-built apps</h1><p class="mt-5 max-w-2xl text-lg leading-8 text-text-muted">Practical checks for the issues that AI-generated apps miss most often. Each tool keeps sensitive input in your browser and explains its limits.</p><div class="mt-10 divide-y divide-border rounded-2xl border border-border bg-bg-raised">{tools.map((tool, index) => <article class="grid gap-4 p-6 md:grid-cols-[3rem_1fr_auto] md:items-center"><span class="flex size-10 items-center justify-center rounded-full bg-accent-dim font-mono text-sm font-semibold text-accent">{index + 1}</span><div><h2 class="text-xl font-semibold text-text"><a href={toolUrl(tool.slug)} class="hover:text-accent">{tool.title}</a></h2><p class="mt-2 text-text-muted">{tool.description}</p><p class="mt-3 text-sm text-text-muted">{tool.privacy}</p></div><a href={toolUrl(tool.slug)} class="inline-flex min-h-11 items-center justify-center rounded-lg bg-accent px-4 text-sm font-semibold text-bg hover:opacity-90">Open tool</a></article>)}</div><section class="mt-16 max-w-3xl"><h2 class="text-2xl font-semibold text-text">What the complete app adds</h2><p class="mt-4 text-text-muted">The tools are deliberately narrow. LyraShield AI adds authorized target scanning, SCA and secret checks, verified findings, approval-gated fix proposals, retests, reports, schedules, notifications, and workspace-scoped audit history.</p></section></section>
</Base>
