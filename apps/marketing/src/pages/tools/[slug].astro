---
import ToolLayout from "@layouts/ToolLayout.astro"
import { tools } from "../../lib/tools"

export function getStaticPaths() { return tools.map((tool) => ({ params: { slug: tool.slug }, props: { tool } })) }
const { tool } = Astro.props
const faq = [
  { q: "Does this upload my input?", a: tool.privacy },
  { q: "Does a clear result mean my app is secure?", a: "No. Each result is limited to the checks shown here. Use it as a next-step guide, then test the relevant application path." },
]
---
<ToolLayout tool={tool} faq={faq}>
  {tool.slug === "ai-app-security-checklist" && <><form id="checklist" class="space-y-3"><p class="text-sm text-text-muted">Select the controls you can show are in place.</p>{["Server-side authorization protects every sensitive action", "Tenant and database policies are tested with two accounts", "Secrets are not committed or sent to browser code", "Input validation runs on every server boundary", "Dependencies and install scripts were reviewed", "Backups, monitoring, and an owner for incidents are documented"].map((item, index) => <label class="flex gap-3 rounded-lg border border-border p-3 text-sm text-text"><input type="checkbox" name="check" value={index} class="mt-0.5 size-4 accent-accent" />{item}</label>)}<button class="mt-2 min-h-11 rounded-lg bg-accent px-4 text-sm font-semibold text-bg" type="submit">Prioritize next steps</button></form><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
  {tool.slug === "secret-exposure-scanner" && <><label class="block text-sm font-medium text-text" for="secret-files">Choose text files to scan locally</label><input id="secret-files" type="file" multiple accept=".env,.txt,.js,.ts,.tsx,.json,.yaml,.yml,.py,.go,.java,.rb,.php" class="mt-3 block w-full text-sm text-text-muted" /><p class="mt-3 text-sm text-text-muted">Files over 1 MB and non-text files are skipped. Matches are redacted before display.</p><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
  {tool.slug === "supabase-rls-checker" && <><label class="block text-sm font-medium text-text" for="sql-input">Paste a policy migration or table policy SQL</label><textarea id="sql-input" rows="12" class="mt-3 w-full rounded-lg border border-border bg-bg p-3 font-mono text-sm text-text" placeholder="alter table public.projects enable row level security;"></textarea><button id="run-rls" class="mt-3 min-h-11 rounded-lg bg-accent px-4 text-sm font-semibold text-bg" type="button">Review SQL locally</button><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
  {tool.slug === "jwt-session-inspector" && <><label class="block text-sm font-medium text-text" for="jwt-input">Paste a non-production JWT only</label><textarea id="jwt-input" rows="4" class="mt-3 w-full rounded-lg border border-border bg-bg p-3 font-mono text-sm text-text" placeholder="eyJ..."></textarea><button id="run-jwt" class="mt-3 min-h-11 rounded-lg bg-accent px-4 text-sm font-semibold text-bg" type="button">Decode locally</button><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
  {tool.slug === "security-headers-checker" && <><label class="block text-sm font-medium text-text" for="headers-input">Paste response headers from your browser network panel</label><textarea id="headers-input" rows="10" class="mt-3 w-full rounded-lg border border-border bg-bg p-3 font-mono text-sm text-text" placeholder="content-security-policy: default-src 'self'\nstrict-transport-security: max-age=31536000"></textarea><button id="run-headers" class="mt-3 min-h-11 rounded-lg bg-accent px-4 text-sm font-semibold text-bg" type="button">Review headers locally</button><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
</ToolLayout>

<script is:inline>
  const result = document.querySelector("#tool-result")
  const show = (items) => { result.innerHTML = `<ul class="space-y-2">${items.map((item) => `<li class="rounded-lg border border-border bg-bg p-3 text-sm text-text">${item}</li>`).join("")}</ul>` }
  document.querySelector("#checklist")?.addEventListener("submit", (event) => { event.preventDefault(); const selected = document.querySelectorAll('input[name="check"]:checked').length; const total = document.querySelectorAll('input[name="check"]').length; show([`${selected}/${total} controls documented.`, selected === total ? "Good start. Validate the implementation with a real scan and retest." : "Start with the unchecked controls; access control and secrets are usually the highest-risk gaps."]) })
  document.querySelector("#secret-files")?.addEventListener("change", async (event) => { const files = [...event.target.files].slice(0, 20); const findings = []; for (const file of files) { if (file.size > 1_000_000) { findings.push(`${file.name}: skipped because it exceeds 1 MB.`); continue } const text = await file.text(); const matches = text.matchAll(/(?:sk-[A-Za-z0-9_-]{16,}|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----|(?:api[_-]?key|secret|token)\s*[:=]\s*["']?([A-Za-z0-9_-]{16,}))/gi); for (const match of matches) { const value = match[0]; findings.push(`${file.name}: possible secret ${value.slice(0, 8)}…${value.slice(-4)} — rotate if real.`) } } show(findings.length ? findings : ["No high-confidence patterns found in the selected files."]) })
  document.querySelector("#run-rls")?.addEventListener("click", () => { const sql = document.querySelector("#sql-input").value.toLowerCase(); const items = []; if (!/enable row level security/.test(sql)) items.push("No ENABLE ROW LEVEL SECURITY statement found."); if (/create policy[\s\S]*using\s*\(\s*true\s*\)/.test(sql)) items.push("A policy appears to allow every row with USING (true)."); if (/security definer/.test(sql)) items.push("SECURITY DEFINER needs a careful search_path and authorization review."); if (!/(auth\.uid\(\)|auth\.jwt\(\)|organization_id|user_id)/.test(sql)) items.push("No obvious ownership predicate was found; verify with two accounts."); show(items.length ? items : ["No simple risky pattern found. Confirm behavior with a real two-account test."]) })
  document.querySelector("#run-jwt")?.addEventListener("click", () => { try { const token = document.querySelector("#jwt-input").value.trim().split("."); if (token.length < 2) throw new Error("A JWT needs header.payload.signature segments."); const decode = (part) => JSON.parse(decodeURIComponent(escape(atob(part.replace(/-/g, "+").replace(/_/g, "/"))))); const header = decode(token[0]); const claims = decode(token[1]); const items = [`Algorithm: ${header.alg || "missing"}.`, `Issuer: ${claims.iss || "missing"}; audience: ${claims.aud || "missing"}.`, `Expiry: ${claims.exp ? new Date(claims.exp * 1000).toISOString() : "missing"}.`]; if (header.alg === "none") items.push("Unsafe: alg=none must never be accepted."); if (claims.exp && claims.exp * 1000 < Date.now()) items.push("This token is expired."); show(items) } catch (error) { show([error.message]) } })
  document.querySelector("#run-headers")?.addEventListener("click", () => { const raw = document.querySelector("#headers-input").value.toLowerCase(); const items = []; for (const [header, message] of [["content-security-policy", "Missing Content-Security-Policy."], ["strict-transport-security", "Missing Strict-Transport-Security."], ["x-content-type-options", "Missing X-Content-Type-Options."], ["referrer-policy", "Missing Referrer-Policy."], ["permissions-policy", "Missing Permissions-Policy."]]) if (!raw.includes(header)) items.push(message); if (/access-control-allow-origin:\s*\*/.test(raw)) items.push("CORS allows every origin; never combine this with credentialed private data."); show(items.length ? items : ["No common header omission found in the pasted response. Review values and route-specific behavior too."]) })
</script>
