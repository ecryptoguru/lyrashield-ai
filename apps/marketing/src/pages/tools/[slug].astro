---
import ToolLayout from "@layouts/ToolLayout.astro"
import { tools } from "../../lib/tools"
import { LAUNCH_CHECKLIST_VERSION, LAUNCH_CHECKS } from "../../lib/tool-checks"

export function getStaticPaths() { return tools.map((tool) => ({ params: { slug: tool.slug }, props: { tool } })) }
const { tool } = Astro.props
const faq = [
  { q: "Does this upload my input?", a: tool.privacy },
  { q: "Does a clear result mean my app is secure?", a: "No. Each result is limited to the checks shown here. Use it as a next-step guide, then test the relevant application path." },
]

const fieldClass =
  "mt-3 w-full rounded-xl border border-border bg-bg p-3 font-mono text-sm text-text shadow-sm transition-colors placeholder:text-text-muted focus:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
const buttonClass =
  "lift mt-4 inline-flex min-h-11 items-center gap-2 rounded-lg bg-accent px-5 text-sm font-semibold text-bg hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg-raised"
const labelClass = "block text-sm font-medium text-text"
---
<ToolLayout tool={tool} faq={faq}>
  {tool.slug === "ai-app-security-checklist" && (
    <>
      <form id="checklist" class="space-y-4" data-version={LAUNCH_CHECKLIST_VERSION}>
        <div>
          <p class="text-sm text-text-muted">Select the controls you can show are in place. Checklist {LAUNCH_CHECKLIST_VERSION}.</p>
          <div class="mt-3 flex items-center gap-3">
            <div class="h-1.5 flex-1 overflow-hidden rounded-full bg-border"><div id="checklist-bar" class="h-full w-0 rounded-full bg-accent transition-[width] duration-300 ease-out"></div></div>
            <span id="checklist-count" class="font-mono text-xs tabular-nums text-text-muted">0/{LAUNCH_CHECKS.length}</span>
          </div>
        </div>
        <div class="space-y-2.5">
          {LAUNCH_CHECKS.map((item, index) => (
            <label class="flex cursor-pointer gap-3 rounded-lg border border-border p-3 text-sm text-text transition-colors hover:border-accent/60 has-checked:border-accent has-checked:bg-accent-dim/30">
              <input type="checkbox" name="check" value={index} class="mt-0.5 size-4 shrink-0 accent-accent" />
              <span>{item}</span>
            </label>
          ))}
        </div>
        <button class={buttonClass} type="submit">Prioritize next steps</button>
      </form>
      <output id="tool-result" class="mt-6 block" aria-live="polite"></output>
    </>
  )}
  {tool.slug === "secret-exposure-scanner" && (
    <>
      <label class={labelClass} for="secret-files">Choose text files to scan locally</label>
      <input id="secret-files" type="file" multiple accept=".env,.txt,.js,.ts,.tsx,.json,.yaml,.yml,.toml,.md,.sql,.sh,.py,.go,.java,.rb,.php" class="mt-3 block w-full cursor-pointer rounded-xl border border-dashed border-border bg-bg p-4 text-sm text-text-muted transition-colors hover:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent file:mr-4 file:cursor-pointer file:rounded-lg file:border-0 file:bg-accent file:px-4 file:py-2 file:text-sm file:font-semibold file:text-bg hover:file:opacity-90" />
      <p class="mt-3 text-sm text-text-muted">Files over 1 MB and non-text files are skipped. Matches are redacted before display.</p>
      <output id="tool-result" class="mt-6 block" aria-live="polite"></output>
    </>
  )}
  {tool.slug === "supabase-rls-checker" && (
    <>
      <label class={labelClass} for="sql-input">Paste a policy migration or table policy SQL</label>
      <textarea id="sql-input" rows="12" class={fieldClass} placeholder="alter table public.projects enable row level security;"></textarea>
      <button id="run-rls" class={buttonClass} type="button">Review SQL locally</button>
      <output id="tool-result" class="mt-6 block" aria-live="polite"></output>
    </>
  )}
  {tool.slug === "jwt-session-inspector" && (
    <>
      <label class={labelClass} for="jwt-input">Paste a non-production JWT only</label>
      <textarea id="jwt-input" rows="4" class={fieldClass} placeholder="eyJ..."></textarea>
      <label class={`mt-4 ${labelClass}`} for="cookie-input">Optional: paste a Set-Cookie response header</label>
      <textarea id="cookie-input" rows="3" class={fieldClass} placeholder="session=...; Secure; HttpOnly; SameSite=Lax"></textarea>
      <button id="run-jwt" class={buttonClass} type="button">Inspect locally</button>
      <output id="tool-result" class="mt-6 block" aria-live="polite"></output>
    </>
  )}
  {tool.slug === "security-headers-checker" && (
    <>
      <label class={labelClass} for="headers-input">Paste response headers from your browser network panel</label>
      <textarea id="headers-input" rows="10" class={fieldClass} placeholder="content-security-policy: default-src 'self'&#10;strict-transport-security: max-age=31536000"></textarea>
      <button id="run-headers" class={buttonClass} type="button">Review headers locally</button>
      <output id="tool-result" class="mt-6 block" aria-live="polite"></output>
    </>
  )}
</ToolLayout>

<script>
  import { checkHeaders, checkRlsSql, checkSetCookie, inspectJwt, scanTextForSecrets } from "../../lib/tool-checks"

  type Severity = "attention" | "info"

  // Presentational hinting only — the result copy itself carries the honest
  // wording. We deliberately use just two tiers: an "attention" accent for
  // clear action items, and a neutral tier for everything else. We never show
  // a green "pass" glyph, since a local check cannot establish that anything
  // is secure (e.g. "No ... protection found" is an absence to fix, not a win).
  const ATTENTION =
    /\b(missing|unsafe|must never|expired|rotate|exposed|wildcard|permissive|not set|insecure|without|disable[ds]?)\b|\bno\b[^.]*\bprotection\b/i

  const COLOR: Record<Severity, string> = {
    attention: "var(--danger)",
    info: "var(--border)",
  }
  const GLYPH: Record<Severity, string> = { attention: "!", info: "•" }

  function severityOf(text: string): Severity {
    return ATTENTION.test(text) ? "attention" : "info"
  }

  function renderHint(output: Element) {
    const hint = document.createElement("p")
    hint.className =
      "rounded-lg border border-dashed border-border bg-bg px-4 py-6 text-center text-sm text-text-muted"
    hint.textContent = "Results appear here. Everything runs locally — nothing is uploaded."
    output.replaceChildren(hint)
  }

  const show = (items: string[]) => {
    const result = document.querySelector("#tool-result")
    if (!result) return
    if (items.length === 0) {
      renderHint(result)
      return
    }

    const wrap = document.createElement("div")

    const head = document.createElement("div")
    head.className = "mb-3 flex items-center justify-between gap-3"
    const label = document.createElement("p")
    label.className = "font-mono text-xs uppercase tracking-[.14em] text-text-muted"
    label.textContent = `Result · ${items.length} observation${items.length === 1 ? "" : "s"}`
    head.appendChild(label)

    const copy = document.createElement("button")
    copy.type = "button"
    copy.className =
      "inline-flex min-h-9 items-center rounded-lg border border-border px-3 text-xs font-semibold text-text-muted transition-colors hover:border-accent hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
    copy.textContent = "Copy"
    copy.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(items.join("\n"))
        copy.textContent = "Copied"
      } catch {
        copy.textContent = "Copy failed"
      }
      setTimeout(() => (copy.textContent = "Copy"), 1500)
    })
    head.appendChild(copy)
    wrap.appendChild(head)

    const list = document.createElement("ul")
    list.className = "space-y-2"
    for (const item of items) {
      const sev = severityOf(item)
      const row = document.createElement("li")
      row.className = "flex gap-3 rounded-lg border border-border bg-bg p-3 text-sm text-text"
      row.style.borderLeftWidth = "4px"
      row.style.borderLeftColor = COLOR[sev]
      const glyph = document.createElement("span")
      glyph.className = "mt-px shrink-0 font-mono font-bold"
      glyph.style.color = sev === "info" ? "var(--text-muted)" : COLOR[sev]
      glyph.setAttribute("aria-hidden", "true")
      glyph.textContent = GLYPH[sev]
      const body = document.createElement("span")
      body.textContent = item
      row.appendChild(glyph)
      row.appendChild(body)
      list.appendChild(row)
    }
    wrap.appendChild(list)
    result.replaceChildren(wrap)
  }

  // Initial empty-state hint on whichever tool output is present.
  const output = document.querySelector("#tool-result")
  if (output && output.childElementCount === 0) renderHint(output)

  // Live checklist progress.
  const checklistForm = document.querySelector<HTMLFormElement>("#checklist")
  if (checklistForm) {
    const boxes = [...checklistForm.querySelectorAll<HTMLInputElement>('input[name="check"]')]
    const bar = document.querySelector<HTMLElement>("#checklist-bar")
    const count = document.querySelector<HTMLElement>("#checklist-count")
    const update = () => {
      const done = boxes.filter((box) => box.checked).length
      if (bar) bar.style.width = `${(done / Math.max(boxes.length, 1)) * 100}%`
      if (count) count.textContent = `${done}/${boxes.length}`
    }
    boxes.forEach((box) => box.addEventListener("change", update))
    update()
  }

  checklistForm?.addEventListener("submit", (event) => {
    event.preventDefault()
    const inputs = [...document.querySelectorAll<HTMLInputElement>('input[name="check"]')]
    const missing = inputs.filter((input) => !input.checked).map((input) => input.parentElement?.textContent?.trim()).filter(Boolean)
    show([
      `${inputs.length - missing.length}/${inputs.length} controls documented.`,
      missing.length
        ? `Start next with: ${missing.slice(0, 3).join("; ")}.`
        : "Good start. Validate the implementation with a real scan and retest.",
    ])
  })

  document.querySelector<HTMLInputElement>("#secret-files")?.addEventListener("change", async (event) => {
    const input = event.currentTarget
    if (!(input instanceof HTMLInputElement)) return
    const files = [...(input.files ?? [])].slice(0, 20)
    const findings: string[] = []
    for (const file of files) {
      if (file.size > 1_000_000) {
        findings.push(`${file.name}: skipped because it exceeds 1 MB.`)
        continue
      }
      const text = await file.text()
      for (const observation of scanTextForSecrets(text)) {
        findings.push(`${file.name}: possible ${observation.kind} ${observation.preview}; rotate it if real.`)
      }
    }
    show(findings.length ? findings : ["No high-confidence patterns found in the selected files."])
  })

  document.querySelector<HTMLButtonElement>("#run-rls")?.addEventListener("click", () => {
    show(checkRlsSql(document.querySelector<HTMLTextAreaElement>("#sql-input")?.value ?? ""))
  })

  document.querySelector<HTMLButtonElement>("#run-jwt")?.addEventListener("click", () => {
    try {
      show([
        ...inspectJwt(document.querySelector<HTMLTextAreaElement>("#jwt-input")?.value ?? ""),
        ...checkSetCookie(document.querySelector<HTMLTextAreaElement>("#cookie-input")?.value ?? ""),
      ])
    } catch (error) {
      show([error instanceof Error ? error.message : "The JWT could not be decoded."])
    }
  })

  document.querySelector<HTMLButtonElement>("#run-headers")?.addEventListener("click", () => {
    show(checkHeaders(document.querySelector<HTMLTextAreaElement>("#headers-input")?.value ?? ""))
  })
</script>
