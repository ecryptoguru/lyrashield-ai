---
import ToolLayout from "@layouts/ToolLayout.astro"
import { tools } from "../../lib/tools"
import { LAUNCH_CHECKLIST_VERSION, LAUNCH_CHECKS } from "../../lib/tool-checks"

export function getStaticPaths() { return tools.map((tool) => ({ params: { slug: tool.slug }, props: { tool } })) }
const { tool } = Astro.props
const faq = [
  { q: "Does this upload my input?", a: tool.privacy },
  { q: "Does a clear result mean my app is secure?", a: "No. Each result is limited to the checks shown here. Use it as a next-step guide, then test the relevant application path." },
]
---
<ToolLayout tool={tool} faq={faq}>
  {tool.slug === "ai-app-security-checklist" && <><form id="checklist" class="space-y-3" data-version={LAUNCH_CHECKLIST_VERSION}><p class="text-sm text-text-muted">Select the controls you can show are in place. Checklist {LAUNCH_CHECKLIST_VERSION}.</p>{LAUNCH_CHECKS.map((item, index) => <label class="flex gap-3 rounded-lg border border-border p-3 text-sm text-text"><input type="checkbox" name="check" value={index} class="mt-0.5 size-4 accent-accent" />{item}</label>)}<button class="lift mt-2 min-h-11 rounded-lg bg-accent px-4 text-sm font-semibold text-bg hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent" type="submit">Prioritize next steps</button></form><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
  {tool.slug === "secret-exposure-scanner" && <><label class="block text-sm font-medium text-text" for="secret-files">Choose text files to scan locally</label><input id="secret-files" type="file" multiple accept=".env,.txt,.js,.ts,.tsx,.json,.yaml,.yml,.toml,.md,.sql,.sh,.py,.go,.java,.rb,.php" class="mt-3 block w-full text-sm text-text-muted" /><p class="mt-3 text-sm text-text-muted">Files over 1 MB and non-text files are skipped. Matches are redacted before display.</p><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
  {tool.slug === "supabase-rls-checker" && <><label class="block text-sm font-medium text-text" for="sql-input">Paste a policy migration or table policy SQL</label><textarea id="sql-input" rows="12" class="mt-3 w-full rounded-lg border border-border bg-bg p-3 font-mono text-sm text-text" placeholder="alter table public.projects enable row level security;"></textarea><button id="run-rls" class="lift mt-3 min-h-11 rounded-lg bg-accent px-4 text-sm font-semibold text-bg hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent" type="button">Review SQL locally</button><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
  {tool.slug === "jwt-session-inspector" && <><label class="block text-sm font-medium text-text" for="jwt-input">Paste a non-production JWT only</label><textarea id="jwt-input" rows="4" class="mt-3 w-full rounded-lg border border-border bg-bg p-3 font-mono text-sm text-text" placeholder="eyJ..."></textarea><label class="mt-4 block text-sm font-medium text-text" for="cookie-input">Optional: paste a Set-Cookie response header</label><textarea id="cookie-input" rows="3" class="mt-3 w-full rounded-lg border border-border bg-bg p-3 font-mono text-sm text-text" placeholder="session=...; Secure; HttpOnly; SameSite=Lax"></textarea><button id="run-jwt" class="lift mt-3 min-h-11 rounded-lg bg-accent px-4 text-sm font-semibold text-bg hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent" type="button">Inspect locally</button><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
  {tool.slug === "security-headers-checker" && <><label class="block text-sm font-medium text-text" for="headers-input">Paste response headers from your browser network panel</label><textarea id="headers-input" rows="10" class="mt-3 w-full rounded-lg border border-border bg-bg p-3 font-mono text-sm text-text" placeholder="content-security-policy: default-src 'self'\nstrict-transport-security: max-age=31536000"></textarea><button id="run-headers" class="lift mt-3 min-h-11 rounded-lg bg-accent px-4 text-sm font-semibold text-bg hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent" type="button">Review headers locally</button><output id="tool-result" class="mt-5 block" aria-live="polite"></output></>}
</ToolLayout>

<script>
  import { checkHeaders, checkRlsSql, checkSetCookie, inspectJwt, scanTextForSecrets } from "../../lib/tool-checks"

  const show = (items: string[]) => {
    const result = document.querySelector("#tool-result")
    if (!result) return
    const list = document.createElement("ul")
    list.className = "space-y-2"
    for (const item of items) {
      const row = document.createElement("li")
      row.className = "rounded-lg border border-border bg-bg p-3 text-sm text-text"
      row.textContent = item
      list.appendChild(row)
    }
    result.replaceChildren(list)
  }

  document.querySelector<HTMLFormElement>("#checklist")?.addEventListener("submit", (event) => {
    event.preventDefault()
    const inputs = [...document.querySelectorAll<HTMLInputElement>('input[name="check"]')]
    const missing = inputs.filter((input) => !input.checked).map((input) => input.parentElement?.textContent?.trim()).filter(Boolean)
    show([
      `${inputs.length - missing.length}/${inputs.length} controls documented.`,
      missing.length
        ? `Start next with: ${missing.slice(0, 3).join("; ")}.`
        : "Good start. Validate the implementation with a real scan and retest.",
    ])
  })

  document.querySelector<HTMLInputElement>("#secret-files")?.addEventListener("change", async (event) => {
    const input = event.currentTarget
    if (!(input instanceof HTMLInputElement)) return
    const files = [...(input.files ?? [])].slice(0, 20)
    const findings: string[] = []
    for (const file of files) {
      if (file.size > 1_000_000) {
        findings.push(`${file.name}: skipped because it exceeds 1 MB.`)
        continue
      }
      const text = await file.text()
      for (const observation of scanTextForSecrets(text)) {
        findings.push(`${file.name}: possible ${observation.kind} ${observation.preview}; rotate it if real.`)
      }
    }
    show(findings.length ? findings : ["No high-confidence patterns found in the selected files."])
  })

  document.querySelector<HTMLButtonElement>("#run-rls")?.addEventListener("click", () => {
    show(checkRlsSql(document.querySelector<HTMLTextAreaElement>("#sql-input")?.value ?? ""))
  })

  document.querySelector<HTMLButtonElement>("#run-jwt")?.addEventListener("click", () => {
    try {
      show([
        ...inspectJwt(document.querySelector<HTMLTextAreaElement>("#jwt-input")?.value ?? ""),
        ...checkSetCookie(document.querySelector<HTMLTextAreaElement>("#cookie-input")?.value ?? ""),
      ])
    } catch (error) {
      show([error instanceof Error ? error.message : "The JWT could not be decoded."])
    }
  })

  document.querySelector<HTMLButtonElement>("#run-headers")?.addEventListener("click", () => {
    show(checkHeaders(document.querySelector<HTMLTextAreaElement>("#headers-input")?.value ?? ""))
  })
</script>
