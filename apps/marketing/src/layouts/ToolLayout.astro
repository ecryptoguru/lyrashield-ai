---
import Base from "@layouts/Base.astro"
import type { Tool } from "../lib/tools"

interface Props { tool: Tool; faq?: Array<{ q: string; a: string }> }
const { tool, faq = [] } = Astro.props
const origin = Astro.site?.origin || "http://localhost:4321"
const canonical = new URL(`/tools/${tool.slug}`, origin).toString()
const jsonLd = [
  { "@context": "https://schema.org", "@type": "WebApplication", name: tool.title, applicationCategory: "SecurityApplication", operatingSystem: "Web", url: canonical, description: tool.description, featureList: tool.checks, provider: { "@id": `${origin}/#organization` } },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", itemListElement: [{ "@type": "ListItem", position: 1, name: "Home", item: `${origin}/` }, { "@type": "ListItem", position: 2, name: "Tools", item: new URL("/tools", origin).toString() }, { "@type": "ListItem", position: 3, name: tool.title, item: canonical }] },
  ...(faq.length ? [{ "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq.map(({ q, a }) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } })) }] : []),
]
---
<Base title={tool.seoTitle} description={tool.description} canonical={canonical} jsonLd={jsonLd}>
  <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:py-16">
    <header data-reveal-group>
      <div class="mb-6 flex items-center gap-3" data-reveal="fade">
        <a href="/tools" class="link-underline inline-flex min-h-11 items-center text-sm font-medium text-text-muted hover:text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"><span aria-hidden="true" class="mr-1.5">←</span>All tools</a>
      </div>
      <p class="font-mono text-xs font-semibold uppercase tracking-[.18em] text-accent" data-reveal>{tool.category}</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight text-text sm:text-5xl" data-reveal>{tool.title}</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-text-muted" data-reveal>{tool.summary}</p>
      <p class="mt-5 flex items-start gap-2.5 rounded-xl border border-border bg-bg-raised px-4 py-3 text-sm text-text-muted" data-reveal="fade">
        <svg viewBox="0 0 24 24" class="mt-0.5 size-4 shrink-0 text-accent" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 3 4 6v6c0 4.5 3.2 7.7 8 9 4.8-1.3 8-4.5 8-9V6l-8-3Z"/></svg>
        <span><strong class="text-text">Local analyzer:</strong> Runs entirely in this browser. {tool.privacy}</span>
      </p>
    </header>
    <div class="mt-8 overflow-hidden rounded-2xl border border-border bg-bg-raised shadow-sm" data-reveal="scale" style="--reveal-shift: 1.5rem">
      <div class="flex items-center justify-between gap-3 border-b border-border px-5 py-3 sm:px-8">
        <span class="font-mono text-xs font-semibold uppercase tracking-[.16em] text-accent">Run the check</span>
        <span class="flex items-center gap-1.5 font-mono text-xs text-text-muted"><span class="inline-block size-1.5 rounded-full bg-accent" aria-hidden="true"></span>Local · nothing uploaded</span>
      </div>
      <div class="p-5 sm:p-8"><slot /></div>
    </div>
    <section class="mt-12 grid gap-8 border-t border-border pt-10 md:grid-cols-2" data-reveal-group>
      <div data-reveal="left">
        <h2 class="text-xl font-semibold text-text">What this checks</h2>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-text-muted">{tool.checks.map((item) => <li class="flex gap-3"><span class="mt-2 size-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true"></span><span>{item}</span></li>)}</ul>
      </div>
      <div data-reveal="right">
        <h2 class="text-xl font-semibold text-text">What this cannot prove</h2>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-text-muted">{tool.limitations.map((item) => <li class="flex gap-3"><span class="mt-2 size-1.5 shrink-0 rounded-full bg-text-muted" aria-hidden="true"></span><span>{item}</span></li>)}</ul>
      </div>
    </section>
    <section aria-labelledby="sources-heading" class="mt-10 border-t border-border pt-8" data-reveal="fade">
      <h2 id="sources-heading" class="text-xl font-semibold text-text">Primary references</h2>
      <p class="mt-3 text-sm leading-6 text-text-muted">Use these standards and vendor references when you investigate a result. A link does not imply certification or full coverage of the source.</p>
      <ul class="mt-4 flex flex-wrap gap-x-6 gap-y-3">{tool.references.map((reference) => <li><a href={reference.url} target="_blank" rel="noreferrer" class="text-sm font-medium text-accent underline decoration-accent/40 underline-offset-4 hover:decoration-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">{reference.label}<span class="sr-only"> (opens in a new tab)</span></a></li>)}</ul>
    </section>
    <section class="mt-10 rounded-2xl border border-border bg-bg-raised p-6" data-reveal><h2 class="text-xl font-semibold text-text">Need an app-wide assurance record?</h2><p class="mt-3 leading-7 text-text-muted">LyraShield AI adds authorized target scanning, explicit coverage receipts, evidence states, approval-gated fix proposals, server-owned retests, and immutable reports. This browser tool remains guidance, not a security guarantee.</p><a href="/?source=tool#waitlist" class="lift mt-5 inline-flex min-h-11 items-center rounded-lg bg-accent px-4 text-sm font-semibold text-bg hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">Get product updates</a></section>
    {faq.length > 0 && <section class="mt-12" data-reveal="fade"><h2 class="text-2xl font-semibold text-text">Frequently asked questions</h2><div class="mt-4 divide-y divide-border rounded-xl border border-border bg-bg-raised">{faq.map((item) => <details class="p-4"><summary class="cursor-pointer font-medium text-text">{item.q}</summary><p class="mt-3 text-sm leading-6 text-text-muted">{item.a}</p></details>)}</div></section>}
  </section>
</Base>
