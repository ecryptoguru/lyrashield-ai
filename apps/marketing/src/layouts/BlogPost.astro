---
import Base from "@layouts/Base.astro"
import BlogCta from "@components/BlogCta.astro"
import { getEntry } from "astro:content"
import type { CollectionEntry } from "astro:content"

interface Heading {
  depth: number
  slug: string
  text: string
}

interface FaqItem {
  q: string
  a: string
}

interface Props {
  title: string
  description: string
  pubDate: Date
  updatedDate?: Date
  authorId: string
  tags: string[]
  draft: boolean
  canonical?: string
  faq?: FaqItem[]
  headings: Heading[]
  readingMinutes: number
  relatedPosts: CollectionEntry<"blog">[]
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  authorId,
  tags,
  draft,
  canonical,
  faq,
  headings,
  readingMinutes,
  relatedPosts,
} = Astro.props

const author = await getEntry("authors", authorId)
const siteUrl = (import.meta.env.PUBLIC_SITE_URL as string | undefined) || "http://localhost:4321"
const siteOrigin = siteUrl.endsWith("/") ? siteUrl.slice(0, -1) : siteUrl
const pageUrl = new URL(Astro.url.pathname, siteOrigin).toString()
const ogImage = "/og/og-default.png"

const article = {
  publishedTime: pubDate.toISOString(),
  modifiedTime: updatedDate?.toISOString() || pubDate.toISOString(),
  tags,
}

// TOC: h2/h3 only, per the build plan (desktop sidebar).
const tocHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= 3)

const jsonLd: unknown[] = [
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: title,
    description,
    url: pageUrl,
    datePublished: pubDate.toISOString(),
    dateModified: updatedDate?.toISOString() || pubDate.toISOString(),
    author: {
      "@type": "Person",
      name: author?.data.name || "LyraSec Team",
    },
    publisher: {
      "@type": "Organization",
      name: "LyraSec AI",
    },
    mainEntityOfPage: pageUrl,
    keywords: tags.join(", "),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${siteOrigin}/` },
      { "@type": "ListItem", position: 2, name: "Blog", item: `${siteOrigin}/blog` },
      { "@type": "ListItem", position: 3, name: title, item: pageUrl },
    ],
  },
]

if (faq && faq.length > 0) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faq.map((item) => ({
      "@type": "Question",
      name: item.q,
      acceptedAnswer: { "@type": "Answer", text: item.a },
    })),
  })
}
---

<Base
  title={`${title} — LyraSec AI`}
  description={description}
  ogType="article"
  article={article}
  ogImage={ogImage}
  canonical={canonical}
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:grid lg:grid-cols-[minmax(0,1fr)_260px] lg:items-start lg:gap-12 lg:px-8">
    <article class="max-w-3xl">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm text-text-muted">
        <a href="/" class="hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">Home</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <a href="/blog" class="hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">Blog</a>
        <span class="mx-2" aria-hidden="true">/</span>
        <span aria-current="page">{title}</span>
      </nav>

      <header>
        {draft && (
          <span class="mb-4 inline-block rounded-full border border-border bg-bg-raised px-3 py-1 text-xs font-medium text-text-muted">
            Draft
          </span>
        )}
        <h1 class="text-3xl font-semibold tracking-tight text-text sm:text-4xl">{title}</h1>
        <p class="mt-4 text-text-muted">
          <time datetime={pubDate.toISOString()}>
            {pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </time>
          {updatedDate && (
            <span class="ml-2 text-sm">
              (updated <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>)
            </span>
          )}
          {author && (
            <span class="ml-2">· {author.data.name}</span>
          )}
          <span class="ml-2">· {readingMinutes} min read</span>
        </p>
      </header>

      <div class="prose prose-invert mt-10 max-w-none prose-a:text-accent prose-headings:tracking-tight prose-headings:text-text">
        <slot />
      </div>

      {faq && faq.length > 0 && (
        <section aria-labelledby="post-faq-heading" class="mt-12 border-t border-border pt-8">
          <h2 id="post-faq-heading" class="text-xl font-semibold tracking-tight text-text">Frequently asked</h2>
          <div class="mt-6 space-y-4">
            {faq.map((item) => (
              <details class="group rounded-lg border border-border bg-bg-raised">
                <summary class="cursor-pointer list-none p-4 font-medium text-text focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                  <span class="flex items-center justify-between">
                    {item.q}
                    <span class="transition group-open:rotate-180" aria-hidden="true">▼</span>
                  </span>
                </summary>
                <div class="border-t border-border px-4 pb-4 pt-2 text-text-muted">
                  <p>{item.a}</p>
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      {tags.length > 0 && (
        <footer class="mt-12 border-t border-border pt-6">
          <p class="text-sm text-text-muted">
            Tags:
            {tags.map((tag, index) => (
              <span>
                <a href={`/blog/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`} class="text-accent hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                  {tag}
                </a>
                {index < tags.length - 1 && <span class="mx-1">·</span>}
              </span>
            ))}
          </p>
        </footer>
      )}

      {relatedPosts.length > 0 && (
        <section aria-labelledby="related-heading" class="mt-12 border-t border-border pt-8">
          <h2 id="related-heading" class="text-xl font-semibold tracking-tight text-text">Related posts</h2>
          <ul class="mt-6 space-y-4">
            {relatedPosts.map((related) => (
              <li>
                <a href={`/blog/${related.id}`} class="font-medium text-text hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                  {related.data.title}
                </a>
                <p class="mt-1 text-sm text-text-muted">{related.data.description}</p>
              </li>
            ))}
          </ul>
        </section>
      )}

      <BlogCta />
    </article>

    {tocHeadings.length > 0 && (
      <aside class="hidden lg:block">
        <nav aria-label="Table of contents" class="sticky top-24 rounded-lg border border-border bg-bg-raised p-4 text-sm">
          <p class="font-medium text-text">On this page</p>
          <ul class="mt-3 space-y-2">
            {tocHeadings.map((heading) => (
              <li style={`margin-left: ${(heading.depth - 2) * 0.75}rem`}>
                <a href={`#${heading.slug}`} class="text-text-muted hover:text-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent">
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>
</Base>
