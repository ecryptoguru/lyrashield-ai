{
  "rules": [
    {
      "allowed": {
        "origins": ["https://lyrashieldai.com"],
        "methods": ["GET", "HEAD"],
        "headers": ["Range"]
      },
      "exposeHeaders": [
      "Accept-Ranges",
      "Content-Length",
      "Content-Range",
      "Content-Type",
      "ETag"
      ],
      "maxAgeSeconds": 86400
    }
  ]
}
